# ─── EmuHelper — source URLs are kept out of the public repo ───────────────
# The real source list is private. Build from the committed template:
#   cp app/src/main/java/io/github/mayusi/emuhelper/data/config/Catalog.kt.template \
#      app/src/main/java/io/github/mayusi/emuhelper/data/config/Catalog.kt
app/src/main/java/io/github/mayusi/emuhelper/data/config/Catalog.kt

# ─── Gradle / Android build ────────────────────────────────────────────────
.gradle/
build/
app/build/
*/build/
captures/
.cxx/

# ─── Local config & secrets ────────────────────────────────────────────────
local.properties
*.keystore
*.jks
keystore.properties
google-services.json
secrets.properties
*.env
.env

# ─── NEVER commit emulation keys / firmware (the app ships NONE) ────────────
# Hard guard so no prod.keys/title.keys/firmware blob ever lands in the repo.
# NOTE: patterns target real key/firmware ARTIFACTS only — never source files.
# (Do not use a bare *firmware* glob: it would also ignore Kotlin sources like
#  EmulatorSetupFirmwareScreen.kt, which MUST be committed.)
*.keys
prod.keys
title.keys
keys.txt
*.nca
*.nsp
*.xci
/keys/
/firmware/
firmware/*.zip
*.firmware

# ─── IDE ───────────────────────────────────────────────────────────────────
.idea/
*.iml
.DS_Store
*.swp

# ─── Misc / scratch ────────────────────────────────────────────────────────
*.log
_*.png
_*.txt
_*.sh
*.apk
*.aab
docs/superpowers/
